// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  PLATFORM_ADMIN
  USER
}

enum CompanyRole {
  OWNER
  ADMIN
  EMPLOYEE
  FINANCE
  VIEWER
}

enum RegistrationType {
  COMPANY_OWNER_SIGNUP
  EMPLOYEE_INVITE
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  firstName          String
  lastName           String
  passwordHash       String
  platformRole       PlatformRole    @default(USER)
  mustChangePassword Boolean         @default(false)
  failedLoginAttempts Int            @default(0)
  lockUntil          DateTime?
  isActive           Boolean         @default(true)

  companyUsers       CompanyUser[]
  securityQAs        UserSecurityQA[]

  createdRegistrationRequests RegistrationRequest[] @relation("CreatedBy")
  decidedRegistrationRequests RegistrationRequest[] @relation("DecidedBy")

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Company {
  id          String        @id @default(uuid())
  name        String
  category    String
  logoUrl     String?
  matricule   String?

  users       CompanyUser[]
  registrationRequests RegistrationRequest[] @relation("RequestedCompany")

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model CompanyUser {
  id        String      @id @default(uuid())
  companyId String
  userId    String
  role      CompanyRole

  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime    @default(now())

  @@unique([companyId, userId])
  @@index([userId])
}

model RegistrationRequest {
  id                String             @id @default(uuid())
  type              RegistrationType
  status            RegistrationStatus @default(PENDING)

  email             String
  firstName         String
  lastName          String

  companyName       String?
  companyCategory   String?

  requestedCompanyId String?
  requestedCompany  Company?           @relation("RequestedCompany", fields: [requestedCompanyId], references: [id])
  requestedCompanyRole CompanyRole?

  rejectionReason   String?

  createdByUserId   String?
  createdByUser     User?              @relation("CreatedBy", fields: [createdByUserId], references: [id])

  decidedByAdminId  String?
  decidedByAdmin    User?              @relation("DecidedBy", fields: [decidedByAdminId], references: [id])
  decidedAt         DateTime?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status, type])
  @@index([email])
}

model UserSecurityQA {
  id         String   @id @default(uuid())
  userId     String
  question   String
  answerHash String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, question])
}
