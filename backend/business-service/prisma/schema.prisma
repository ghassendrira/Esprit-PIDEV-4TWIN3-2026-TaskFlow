generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  logoUrl   String
  currency  String
  taxRate   Float
  category  String   @default("Autre")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  clients Client[]

  @@index([tenantId])
}

model Client {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  name       String
  email      String
  phone      String
  address    String
  taxNumber  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  business Business @relation(fields: [businessId], references: [id])
  communications ClientCommunication[]

  @@index([businessId])
  @@index([email])
}

model ClientCommunication {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  type      String
  date      DateTime
  notes     String
  createdAt DateTime @default(now())
  deletedAt DateTime?

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}