generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  businessId String? @db.Uuid
  tenantId String? @db.Uuid

  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([businessId])
  @@index([tenantId])
}