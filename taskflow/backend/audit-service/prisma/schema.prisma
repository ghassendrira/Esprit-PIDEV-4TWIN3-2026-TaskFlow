
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
}