generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

model Expense {
  id          String     @id @default(uuid()) @db.Uuid
  businessId  String     @db.Uuid
  amount      Float
  date        DateTime
  description String
  receiptUrl  String
  status      ExpenseStatus
  createdBy   String     @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([businessId])
  @@index([createdBy])
  @@index([status])
}

model ExpenseCategory {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  name       String
  description String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([businessId])
  @@index([name])
}
