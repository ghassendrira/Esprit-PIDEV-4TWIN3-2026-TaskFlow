generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  businessId    String        @db.Uuid
  clientId    String   @db.Uuid     

  createdBy      String?       @db.Uuid

  invoiceNumber String
  status        InvoiceStatus
  issueDate     DateTime
  dueDate       DateTime
  totalAmount   Float
  taxAmount     Float
  pdfUrl        String
  notes         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  items    InvoiceItem[]
  payments Payment[]

  @@index([businessId])
  @@index([createdBy])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @db.Uuid
  description String
  quantity    Int
  unitPrice   Float
  amount      Float
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  invoiceId   String        @db.Uuid
  amount      Float
  paymentDate DateTime
  method      PaymentMethod
  reference   String
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}
