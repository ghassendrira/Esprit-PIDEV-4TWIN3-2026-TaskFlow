{
  "name": "taskflow-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200 --no-open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "rxjs": "~7.8.0",
    "speakeasy": "^2.0.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "autoprefixer": "^10.4.19",
    "jsdom": "^27.1.0",
    "postcss": "^8.4.33",
    "sass-embedded": "^1.80.6",
    "tailwindcss": "^3.4.11",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
